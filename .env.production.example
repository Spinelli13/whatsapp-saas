# ── Servidor ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
FRONTEND_URL=https://seu-crm.com

# ── Banco de dados ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/whatsapp_saas
DB_SSL=true

# ── JWT ────────────────────────────────────────────────────────────────────────
# Gerar com: node -e "require('crypto').randomBytes(64).toString('hex') |> console.log"
JWT_SECRET=TROQUE_POR_64_BYTES_ALEATORIOS_HEX
JWT_REFRESH_SECRET=TROQUE_POR_64_BYTES_ALEATORIOS_DIFERENTES
JWT_EXPIRES_IN=1h

# ── Criptografia ───────────────────────────────────────────────────────────────
# Deve ter exatamente 32 caracteres (AES-256)
ENCRYPTION_KEY=TROQUE_POR_32_CHARS_EXATOS_AQUI_

# ── Monitoramento ──────────────────────────────────────────────────────────────
SENTRY_DSN=https://PUBLIC_KEY@sentry.io/PROJECT_ID

# ── OAuth Social Login (opcional) ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://seu-crm.com/api/auth/google/callback

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_CALLBACK_URL=https://seu-crm.com/api/auth/microsoft/callback
