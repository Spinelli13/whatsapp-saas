# ────────────────────────────────────────────────────────────────
# WhatsApp SaaS — variáveis de ambiente
# Copie para .env e preencha os valores
# NUNCA commite o .env real
# ────────────────────────────────────────────────────────────────

# Servidor
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# Banco de dados (PostgreSQL)
# Local (sem Docker): postgresql://postgres:senha@localhost:5432/whatsapp_saas
# Docker Compose:     postgresql://postgres:senha@postgres:5432/whatsapp_saas
# Render/Produção:    (usar valor fornecido pelo Render)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/whatsapp_saas

# Senha do PostgreSQL (usada pelo docker-compose)
POSTGRES_PASSWORD=postgres

# JWT
JWT_SECRET=troque_por_string_aleatoria_min_32_chars
JWT_EXPIRES_IN=24h

# Porta da API (docker-compose)
API_PORT=3000

# Email (opcional - para notificações futuras)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seu@email.com
# SMTP_PASS=sua_senha_app
